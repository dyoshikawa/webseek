{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "statusLine": {
    "type": "command",
    "command": "pnpm dlx ccstatusline@latest",
    "padding": 0
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
