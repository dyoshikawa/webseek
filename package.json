{
  "name": "webseek",
  "version": "0.2.0",
  "description": "Unified multi-provider web search as a CLI, MCP server, and library (OpenAI, Google Custom Search, Gemini)",
  "keywords": [
    "web-search",
    "search",
    "cli",
    "mcp",
    "openai",
    "google",
    "gemini",
    "serp"
  ],
  "homepage": "https://github.com/dyoshikawa/webseek#readme",
  "bugs": {
    "url": "https://github.com/dyoshikawa/webseek/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dyoshikawa/webseek.git"
  },
  "license": "MIT",
  "author": "dyoshikawa",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "bin": {
    "webseek": "dist/cli/index.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "start": "node dist/cli/index.mjs",
    "dev": "tsx src/cli/index.ts",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "oxlint": "oxlint . --max-warnings 0",
    "oxlint:fix": "oxlint . --fix --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "cspell": "cspell --no-progress --gitignore .",
    "secretlint": "secretlint --secretlintignore .gitignore \"**/*\"",
    "check": "pnpm run fmt:check && pnpm run oxlint && pnpm run typecheck",
    "fix": "pnpm run fmt && pnpm run oxlint:fix",
    "test": "vitest run --config vitest.config.ts --silent=true",
    "test:e2e": "vitest run --config vitest.e2e.config.ts --silent=false",
    "sync:skill-docs": "tsx scripts/sync-skill-docs.ts",
    "check:sync-skill-docs": "tsx scripts/check-skill-docs-sync.ts",
    "cicheck:code": "pnpm run check && pnpm run test",
    "cicheck:content": "pnpm run check:sync-skill-docs && pnpm run cspell && pnpm run secretlint",
    "cicheck": "pnpm run cicheck:code && pnpm run cicheck:content",
    "generate": "rulesync generate",
    "gitignore": "rulesync gitignore",
    "prepare": "simple-git-hooks",
    "prepublishOnly": "pnpm run build"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@openrouter/sdk": "0.13.7",
    "@secretlint/secretlint-rule-preset-recommend": "13.0.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^26.0.0",
    "cspell": "10.0.1",
    "lint-staged": "17.0.7",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "repomix": "1.14.1",
    "resend": "6.14.0",
    "rulesync": "^8.31.0",
    "secretlint": "13.0.2",
    "simple-git-hooks": "2.13.1",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^15.0.0",
    "zod": "^4.4.3"
  }
}
